generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum ClipboardContentType {
  TEXT
  SHARE
}

model Share {
  id            String   @id @default(cuid())
  code          String   @unique
  textContent   String?
  passwordHash  String?
  oneTimeUse    Boolean  @default(false)
  encrypted     Boolean  @default(false)
  downloadCount Int      @default(0)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  userId String?
  ipHash String?

  user User? @relation(fields: [userId], references: [id])

  files File[]

  @@index([expiresAt])
  @@index([ipHash])
}

model File {
  id String @id @default(cuid())

  shareId String
  share   Share  @relation(fields: [shareId], references: [id], onDelete: Cascade)

  url      String
  publicId String

  mimeType     String
  sizeBytes    Int
  originalName String

  createdAt DateTime @default(now())
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  devices       Device[]
  clipboardSync ClipboardSync?
  shares Share[]
}

model Device {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  clientId     String
  name         String
  registeredAt DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@unique([userId, clientId])
  @@index([userId])
}

model ClipboardSync {
  userId      String               @id
  user        User                 @relation(fields: [userId], references: [id])
  contentType ClipboardContentType @default(TEXT)
  textContent String?
  shareId     String?
  updatedAt   DateTime             @updatedAt
}
