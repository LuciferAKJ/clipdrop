generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Share {
  id            String   @id @default(cuid())
  code          String   @unique

  textContent   String?
  passwordHash  String?

  oneTimeUse    Boolean  @default(false)
  encrypted     Boolean  @default(false)

  downloadCount Int      @default(0)

  expiresAt     DateTime
  createdAt     DateTime @default(now())

  files         File[]
}

model File {
  id           String   @id @default(cuid())

  shareId      String

  url          String
  publicId     String

  mimeType     String
  sizeBytes    Int
  originalName String

  createdAt    DateTime @default(now())

  share Share @relation(
    fields: [shareId],
    references: [id],
    onDelete: Cascade
  )
}